GITHUB_TOKEN=your_github_personal_access_token
GITHUB_USERNAME=cb7chaitanya

# ─── VISITOR COUNTER ─────────────────────────────────────────────────────────
# Free counter: https://countapi.xyz
COUNTAPI_NAMESPACE=cb7chaitanya
COUNTAPI_KEY=visits

# ─── CONTACT EMAIL ───────────────────────────────────────────────────────────
