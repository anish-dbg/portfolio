# ─────────────────────────────────────────────────────────────
# Environment variables — copy to `.env.local` and fill in.
# Every widget below gracefully no-ops if its vars are missing,
# so the site runs fine even if you skip everything here.
# ─────────────────────────────────────────────────────────────

# ── NowPlaying widget (Spotify) ───────────────────────────────
# Run `node setup-spotify.mjs` for guided token exchange.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=
# Only needed when running setup-spotify.mjs, not at runtime.
SPOTIFY_REDIRECT_URI=http://localhost:3000/

# ── VisitorWidget (Upstash Redis) ─────────────────────────────
# Free tier at upstash.com. Create a Redis DB → copy REST creds.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
